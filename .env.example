# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=app_db
DB_USERNAME=app_user
DB_PASSWORD=app_password
DB_SSL=false
DB_SYNCHRONIZE=false
DB_LOGGING=false

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1h

# Application Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# Docker Configuration (optional)
POSTGRES_VOLUME_NAME=app_postgres_data

SENDGRID_API_KEY=...

MAIL_DEFAULT_FROM="Projeto Basquete no-reply@seudominio.com"

JOBS_WORKER_ENABLED=true|false

JOBS_WORKER_CONCURRENCY=1

JOBS_WORKER_POLL_MS=2000

JOBS_WORKER_BATCH_SIZE=10

JOBS_WORKER_LOCK_TTL_SECONDS=300
